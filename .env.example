# SLAIF API Gateway environment template.
# Copy to .env for local development, then replace every production secret.
# Never commit real secrets, provider keys, SMTP passwords, or live credentials.

# ---------------------------------------------------------------------------
# App / base URLs
# ---------------------------------------------------------------------------
APP_ENV=development
APP_BASE_URL=http://localhost:8000
PUBLIC_BASE_URL=http://localhost:8000/v1

# ---------------------------------------------------------------------------
# Gateway key prefix / HMAC
# ---------------------------------------------------------------------------
GATEWAY_KEY_PREFIX=sk-slaif-
GATEWAY_KEY_ACCEPTED_PREFIXES=sk-slaif-
ACTIVE_HMAC_KEY_VERSION=1
TOKEN_HMAC_SECRET_V1=change-me-generate-long-random-secret-at-least-32-chars
# Optional legacy/non-production fallback only. Prefer TOKEN_HMAC_SECRET_V1.
TOKEN_HMAC_SECRET=

# ---------------------------------------------------------------------------
# Admin sessions / one-time secrets
# ---------------------------------------------------------------------------
ADMIN_SESSION_SECRET=change-me-generate-long-random-secret-at-least-32-chars
# Production requires a base64url-encoded 32-byte key. Leave blank until
# generated, because invalid non-empty values fail Settings validation.
ONE_TIME_SECRET_ENCRYPTION_KEY=
ONE_TIME_SECRET_KEY_VERSION=v1
EMAIL_KEY_SECRET_MAX_AGE_SECONDS=86400

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Docker Compose uses the postgres service hostname. For host-local development
# outside Compose, use postgresql+asyncpg://slaif:slaif@localhost:15432/slaif_gateway.
POSTGRES_HOST_PORT=15432
DATABASE_URL=postgresql+asyncpg://slaif:slaif@postgres:5432/slaif_gateway
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT_SECONDS=30
DATABASE_POOL_RECYCLE_SECONDS=1800
DATABASE_POOL_PRE_PING=true
DATABASE_CONNECT_TIMEOUT_SECONDS=10
# DATABASE_STATEMENT_TIMEOUT_MS=

# ---------------------------------------------------------------------------
# Redis / rate limiting
# ---------------------------------------------------------------------------
# Docker Compose uses the redis service hostname. For host-local development
# outside Compose, use redis://localhost:16379/0.
REDIS_HOST_PORT=16379
REDIS_URL=redis://redis:6379/0
REDIS_CONNECT_TIMEOUT_SECONDS=2
REDIS_SOCKET_TIMEOUT_SECONDS=2
ENABLE_REDIS_RATE_LIMITS=false
# DEFAULT_RATE_LIMIT_REQUESTS_PER_MINUTE=
# DEFAULT_RATE_LIMIT_TOKENS_PER_MINUTE=
# DEFAULT_RATE_LIMIT_CONCURRENT_REQUESTS=
# Development default is fail-open when unset; production default is fail-closed.
RATE_LIMIT_FAIL_CLOSED=false
RATE_LIMIT_CONCURRENCY_TTL_SECONDS=300
RATE_LIMIT_CONCURRENCY_HEARTBEAT_SECONDS=30
RATE_LIMIT_CONCURRENCY_TTL_GRACE_SECONDS=30

# ---------------------------------------------------------------------------
# Provider keys
# ---------------------------------------------------------------------------
# Do not use OPENAI_API_KEY as the gateway's upstream OpenAI provider key.
# OPENAI_API_KEY is for clients using a gateway-issued key.
# Provider keys should come from environment variables or deployment secrets.
# In production, enabled providers require non-placeholder values here.
OPENAI_UPSTREAM_API_KEY=
OPENROUTER_API_KEY=
ENABLE_OPENAI_PROVIDER=true
ENABLE_OPENROUTER_PROVIDER=true

# ---------------------------------------------------------------------------
# Request caps
# ---------------------------------------------------------------------------
DEFAULT_MAX_OUTPUT_TOKENS=1024
HARD_MAX_OUTPUT_TOKENS=4096
HARD_MAX_INPUT_TOKENS=128000

# ---------------------------------------------------------------------------
# Metrics / readiness / logging
# ---------------------------------------------------------------------------
ENABLE_METRICS=true
METRICS_REQUIRE_AUTH=true
METRICS_PUBLIC_IN_PRODUCTION=false
METRICS_ALLOWED_IPS=
# READYZ_INCLUDE_DETAILS=
REQUEST_ID_HEADER=X-Request-ID
LOG_LEVEL=INFO
STRUCTURED_LOGS=true

# ---------------------------------------------------------------------------
# Admin dashboard feature flag
# ---------------------------------------------------------------------------
ENABLE_ADMIN_DASHBOARD=true
ADMIN_SESSION_COOKIE_NAME=slaif_admin_session
# Leave unset for environment-sensitive default: Secure in production, not Secure in development/test.
# ADMIN_SESSION_COOKIE_SECURE=
ADMIN_SESSION_COOKIE_HTTPONLY=true
ADMIN_SESSION_COOKIE_SAMESITE=lax
ADMIN_SESSION_TTL_SECONDS=28800
ADMIN_LOGIN_CSRF_COOKIE_NAME=slaif_admin_login_csrf
ADMIN_CSRF_TTL_SECONDS=1800
ADMIN_LOGIN_RATE_LIMIT_ENABLED=true
ADMIN_LOGIN_MAX_FAILED_ATTEMPTS=5
ADMIN_LOGIN_WINDOW_SECONDS=900
ADMIN_LOGIN_LOCKOUT_SECONDS=900

# ---------------------------------------------------------------------------
# Email / Celery / SMTP
# ---------------------------------------------------------------------------
ENABLE_EMAIL_DELIVERY=false
API_HOST_PORT=8000
SMTP_HOST=mailpit
MAILPIT_SMTP_HOST_PORT=1025
MAILPIT_WEB_HOST_PORT=8025
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@example.org
SMTP_USE_TLS=false
SMTP_STARTTLS=false
SMTP_TIMEOUT_SECONDS=10
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=

# Optional Nginx reverse proxy profile.
NGINX_HOST_PORT=8080

# ---------------------------------------------------------------------------
# Scheduled reconciliation
# ---------------------------------------------------------------------------
# Disabled by default. Inspection is safe/reporting only; automatic mutation
# requires the relevant auto-execute flag plus RECONCILIATION_DRY_RUN=false.
ENABLE_SCHEDULED_RECONCILIATION=false
RECONCILIATION_DRY_RUN=true
RECONCILIATION_INTERVAL_SECONDS=300
RECONCILIATION_EXPIRED_RESERVATION_LIMIT=100
RECONCILIATION_PROVIDER_COMPLETED_LIMIT=100
RECONCILIATION_EXPIRED_RESERVATION_OLDER_THAN_SECONDS=0
RECONCILIATION_PROVIDER_COMPLETED_OLDER_THAN_SECONDS=0
RECONCILIATION_AUTO_EXECUTE_EXPIRED_RESERVATIONS=false
RECONCILIATION_AUTO_EXECUTE_PROVIDER_COMPLETED=false
# Optional generic alert webhook for reconciliation backlog inspection. Disabled
# by default; treat the webhook URL as a secret if it contains tokens. Payloads
# contain counts only unless RECONCILIATION_ALERT_INCLUDE_IDS=true.
ENABLE_RECONCILIATION_ALERTS=false
RECONCILIATION_ALERT_WEBHOOK_URL=
RECONCILIATION_ALERT_WEBHOOK_TIMEOUT_SECONDS=10
RECONCILIATION_ALERT_MIN_EXPIRED_RESERVATIONS=1
RECONCILIATION_ALERT_MIN_PROVIDER_COMPLETED=1
RECONCILIATION_ALERT_INCLUDE_IDS=false

# Dashboard pricing import limits. Preview validates CSV/JSON without writes;
# execution requires CSRF, confirmation, audit reason, and all rows to validate.
PRICING_IMPORT_MAX_BYTES=1048576
PRICING_IMPORT_MAX_ROWS=1000

# Dashboard route import limits. Preview validates CSV/JSON without writes;
# execution requires CSRF, confirmation, audit reason, and all rows to validate.
ROUTE_IMPORT_MAX_BYTES=1048576
ROUTE_IMPORT_MAX_ROWS=1000

# Dashboard FX import limits. Preview validates CSV/JSON without writes;
# execution requires CSRF, confirmation, audit reason, and all rows to validate.
FX_IMPORT_MAX_BYTES=1048576
FX_IMPORT_MAX_ROWS=1000

# Dashboard bulk key import preview limits. Preview validates CSV/JSON without
# generating plaintext keys or writing gateway key, one-time secret, email, or audit rows.
KEY_IMPORT_MAX_BYTES=1048576
KEY_IMPORT_MAX_ROWS=1000

# Dashboard usage/audit CSV export row caps. Exports require CSRF,
# explicit confirmation, and an audit reason; generated CSV excludes prompts,
# completions, raw request/response bodies, and secrets.
ADMIN_USAGE_EXPORT_MAX_ROWS=10000
ADMIN_AUDIT_EXPORT_MAX_ROWS=10000
